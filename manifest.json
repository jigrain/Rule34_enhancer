{
  "description": "Adds some features to the rule34.xxx website interface ",
  "manifest_version": 2,
  "name": "Rule34 Enhancer",
  "version": "1.0",
  "homepage_url": "https://github.com/mdn/webextensions-examples/tree/master/borderify",
  "icons": {
    "64": "icons/icon.png"
  },
  
  "permissions": [
    "https://api.rule34.xxx/*",
	"storage",          
    "activeTab", 
	"cookies",
	"tabs",
	"https://wimg.rule34.xxx/*",
	"https://rule34.xxx/*"
  ],
   "background": {
    "scripts": ["background.js", "get_user_id.js"]
	},

  "content_scripts": [
    {
      "matches": ["*://rule34.xxx/*"],
      "js": ["gallery_mod.js"]
    },
	//{
    //  "matches": ["*://rule34.xxx/*"],
    //  "js": ["pixelize.js"]
    //}
	{
      "matches": ["*://rule34.xxx/*"],
      "js": ["load_favorites.js"]
    }
  ]

}