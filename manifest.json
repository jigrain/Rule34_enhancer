{
  "description": "Adds some features to the rule34.xxx website interface ",
  "manifest_version": 2,
  "name": "Rule34 Enhancer",
  "version": "1.0",
  "homepage_url": "https://github.com/jigrain/Rule34_enhancer",
  "icons": {
    "64": "icons/icon.png"
  },
  
  "web_accessible_resources": [
    "galleryStyles.css",
    "gallery_mod.js"
  ],
  
  "permissions": [
    "https://api.rule34.xxx/*",
	  "storage",          
    "activeTab", 
	  "cookies",
	  "tabs",
	  "https://wimg.rule34.xxx/*",
	  "https://rule34.xxx/*",
    "contextMenus"
  ],
   "background": {
    "scripts": ["load_favorites_background.js", "get_user_id.js", "utilities/pixelize_background.js"]
	},

  "content_scripts": [
    {
      "matches": ["*://rule34.xxx/index.php?page=post&s=list*"],
	    "css": ["galleryStyles.css"],
      "js": ["main_search_img.js"]
    },
	{
      "matches": ["*://rule34.xxx/*"],
      "css": ["galleryStyles.css"],
      "js": ["load_favorites.js"]
    },
    {
      "matches": ["*://rule34.xxx/*"],
      "js": ["utilities/open_in_new_tab.js", "utilities/pixelize.js"]
    },
    {
      "matches": ["*://rule34.xxx/index.php?page=post&s=view*"],
      "js": ["utilities/resize_img_view.js"]
    }
  ],
  "options_page": "options.html"
}